<?xml version="1.0" encoding="UTF-8"?>
<inkscape-extension xmlns="http://www.inkscape.org/namespace/inkscape/extension">
    <name>Copy selected objects to pages</name>
    <description>Copy the selected objects to other pages, preserving their position on the page.</description>

    <name lang="de">Auswahl kopieren (auf weitere Seiten)</name>
    <description lang="de">Kopiert die ausgewählten Objekte auf andere Seiten und erhält dabei ihre Position auf der Seite.</description>

    <id>io.github.cr7pt0gr4ph7.inkscape_extensions.copy_selection_to_pages</id>

    <param name="target_pages" type="string" gui-text="Target pages"></param>
    <param name="exclude_source_page" type="bool" gui-text="Exclude source page">true</param>

    <effect>
        <object-type>all</object-type>
        <effects-menu>
            <submenu name="Document"/>
        </effects-menu>
    </effect>

    <script>
        <command location="inx" interpreter="python">copy_selection_to_pages.py</command>
    </script>
</inkscape-extension>
